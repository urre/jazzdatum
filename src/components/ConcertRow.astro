---
import type { Concert } from '../lib/concerts';
import { venueColor, venueTextColor } from '../lib/venueColor';
import { cityFor } from '../lib/venueCity';
import AddToCalendar from './AddToCalendar.astro';
import styles from './ConcertRow.module.css';

interface Props {
  concert: Concert;
}

const { concert } = Astro.props;
const { data, id } = concert;

const vc = venueColor(data.venue);
const venueText = venueTextColor(vc);
const city = cityFor(data.venue);
const href = `/concerts/${id}`;
---

<div class={styles.row}>
  <span class={styles.venue} style={`background:${vc};color:${venueText}`}>{data.venue}</span>

  <span class={styles.main}>
    <a class={styles.titleLink} href={href} aria-label={`${data.artist}, ${data.venue}${city ? `, ${city}` : ''}`}>{data.artist}</a>
    {(city || data.time) && (
      <span class={styles.sub}>{[city, data.time].filter(Boolean).join(' · ')}</span>
    )}
  </span>

  <span class={styles.right}>
    <AddToCalendar
      title={data.artist}
      venue={data.venue}
      date={data.date}
      time={data.time}
      description={data.description}
      uid={id}
      variant="compact"
    />
    <svg class={styles.chevron} width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 6l6 6-6 6" />
    </svg>
  </span>
</div>
