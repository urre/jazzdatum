---
import type { Concert } from '../lib/concerts';
import { groupByDate, uniqueVenues, uniqueFestivals, uniqueCities, cityForVenue } from '../lib/concerts';
import ConcertRow from './ConcertRow.astro';
import styles from './ConcertBrowser.module.css';

interface Props {
  concerts: Concert[];
}

const { concerts } = Astro.props;
const cities = uniqueCities(concerts);
const venues = uniqueVenues(concerts);
const festivals = uniqueFestivals(concerts);
const groups = groupByDate(concerts);

const iso = (d: Date) =>
  `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;

const dates = concerts.map((c) => c.data.date).sort((a, b) => a.getTime() - b.getTime());
const minDate = dates.length ? iso(dates[0]) : undefined;
const maxDate = dates.length ? iso(dates[dates.length - 1]) : undefined;

const searchText = (c: Concert) =>
  [c.data.artist, c.data.venue, c.data.title, c.data.festival].filter(Boolean).join(' ').toLowerCase();

// Comparable local start "YYYY-MM-DDTHH:MM" used to hide concerts whose start
// time has already passed today. Concerts without a known time stay visible
// the whole day (treated as 23:59).
const startKey = (c: Concert) => `${iso(c.data.date)}T${c.data.time ?? '23:59'}`;

// Server-render the first page already paginated so there's no layout shift
// when the client script hydrates (it recomputes the same page-1 state).
const PAGE_SIZE = 25;
const total = concerts.length;
const pageCount = Math.max(1, Math.ceil(total / PAGE_SIZE));
const multiPage = pageCount > 1;
const initialCount =
  total === 0 ? '0 konserter' : `Visar 1–${Math.min(PAGE_SIZE, total)} av ${total} konserter`;
const pageInfoText = `Sida 1 / ${pageCount}`;

let runningIndex = 0;
const groupsWithStart = groups.map((group) => {
  const startIndex = runningIndex;
  runningIndex += group.concerts.length;
  return { group, startIndex };
});
---

<div data-browser class={styles.browser}>
  <aside class={styles.sidebar}>
    <div class={styles.sidebarInner}>
    <slot />

    <button type="button" class={styles.filterToggle} data-sidebar-toggle aria-expanded="false" aria-controls="cb-filters">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 3H2l8 9.5V19l4 2v-8.5L22 3z" />
      </svg>
      <span>Filter</span>
      <svg class={styles.toggleChevron} width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M6 9l6 6 6-6" />
      </svg>
    </button>

    <div class={styles.sidebarBody} id="cb-filters" data-sidebar-body>
      <div class={styles.sidebarHead}>
      <div>
        <p class={styles.sidebarTitle}>Filter</p>
        <p class={styles.activeCount} data-active-count aria-live="polite">Inga aktiva</p>
      </div>
      <button type="button" class={styles.reset} data-reset>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 12a9 9 0 1 0 3-6.7L3 8" /><path d="M3 3v5h5" />
        </svg>
        Rensa
      </button>
    </div>

    <div class={styles.field}>
      <label class={styles.fieldLabel} for="cb-search">Sök</label>
      <div class={styles.searchField}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" /><path d="M21 21l-4.3-4.3" />
        </svg>
        <input
          id="cb-search"
          type="search"
          class={styles.search}
          data-search-input
          placeholder="Artist eller spelställe…"
          aria-label="Sök konserter"
        />
      </div>
    </div>

    {cities.length > 1 && (
      <div class={styles.field}>
        <label class={styles.fieldLabel} for="cb-city">Stad</label>
        <select id="cb-city" class={styles.select} data-city-filter>
          <option value="">Alla städer</option>
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </div>
    )}

    {venues.length > 1 && (
      <div class={styles.field}>
        <label class={styles.fieldLabel} for="cb-venue">Spelställe</label>
        <select id="cb-venue" class={styles.select} data-venue-filter>
          <option value="">Alla spelställen</option>
          {venues.map((v) => <option value={v}>{v}</option>)}
        </select>
      </div>
    )}

    {festivals.length > 0 && (
      <div class={styles.field}>
        <label class={styles.fieldLabel} for="cb-festival">Festival</label>
        <select id="cb-festival" class={styles.select} data-festival-filter>
          <option value="">Alla konserter</option>
          {festivals.map((f) => <option value={f}>{f}</option>)}
        </select>
      </div>
    )}

    <div class={styles.field}>
      <span class={styles.fieldLabel}>Datum</span>
      <div class={styles.dateRow}>
        <input type="date" class={styles.select} data-date-from min={minDate} max={maxDate} aria-label="Från datum" />
        <input type="date" class={styles.select} data-date-to min={minDate} max={maxDate} aria-label="Till datum" />
      </div>
    </div>

    <div class={styles.field}>
      <label class={styles.fieldLabel} for="cb-size">Visa</label>
      <select id="cb-size" class={styles.select} data-page-size>
        <option value="25">25 per sida</option>
        <option value="50">50 per sida</option>
        <option value="100">100 per sida</option>
        <option value="all">Visa alla</option>
      </select>
    </div>

      <slot name="footer" />
    </div>
    </div>
  </aside>

  <div class={styles.main}>
    {total === 0 ? (
      <p class={styles.empty}>Inga kommande konserter just nu. Kolla tillbaka snart!</p>
    ) : (
      <>
        <div class={styles.toolbar}>
          <p class={styles.count} data-count aria-live="polite">{initialCount}</p>

          <nav class:list={[styles.pagination, styles.paginationTop]} data-pagination aria-label="Sidnavigering (topp)" hidden={!multiPage}>
            <button type="button" class={styles.pageBtn} data-prev disabled>← <span class={styles.pageBtnLabel}>Föregående</span></button>
            <span class={styles.pageInfo} data-page-info>{pageInfoText}</span>
            <button type="button" class={styles.pageBtn} data-next disabled={!multiPage}><span class={styles.pageBtnLabel}>Nästa</span> →</button>
          </nav>
        </div>

        <div class={styles.results} data-results>
          {groupsWithStart.map(({ group, startIndex }) => (
            <section class={styles.group} data-group hidden={startIndex >= PAGE_SIZE}>
              <h2 class={styles.dateHeading} data-group-date>{group.label}</h2>
              <ul class={styles.list}>
                {group.concerts.map((concert, i) => (
                  <li
                    data-row
                    data-search={searchText(concert)}
                    data-city={cityForVenue(concert.data.venue)}
                    data-venue={concert.data.venue}
                    data-festival={concert.data.festival ?? ''}
                    data-date={iso(concert.data.date)}
                    data-start={startKey(concert)}
                    hidden={startIndex + i >= PAGE_SIZE}
                  >
                    <ConcertRow concert={concert} />
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>

        <p class={styles.noResults} data-no-results>Inga konserter matchar din filtrering.</p>

        <nav class={styles.pagination} data-pagination aria-label="Sidnavigering" hidden={!multiPage}>
          <button type="button" class={styles.pageBtn} data-prev disabled>← <span class={styles.pageBtnLabel}>Föregående</span></button>
          <span class={styles.pageInfo} data-page-info>{pageInfoText}</span>
          <button type="button" class={styles.pageBtn} data-next disabled={!multiPage}><span class={styles.pageBtnLabel}>Nästa</span> →</button>
        </nav>
      </>
    )}
  </div>
</div>

<script>
  // Re-run on every Astro view-transition navigation, not just first load —
  // bundled scripts execute once, but astro:page-load fires on each swap.
  function initBrowser() {
    const root = document.querySelector<HTMLElement>('[data-browser]');
    if (!root) return;
    const input = root.querySelector<HTMLInputElement>('[data-search-input]');
    const cityFilter = root.querySelector<HTMLSelectElement>('[data-city-filter]');
    const venueFilter = root.querySelector<HTMLSelectElement>('[data-venue-filter]');
    const festivalFilter = root.querySelector<HTMLSelectElement>('[data-festival-filter]');
    const dateFrom = root.querySelector<HTMLInputElement>('[data-date-from]');
    const dateTo = root.querySelector<HTMLInputElement>('[data-date-to]');
    const pageSizeSel = root.querySelector<HTMLSelectElement>('[data-page-size]');
    const resetBtn = root.querySelector<HTMLButtonElement>('[data-reset]');
    const activeCountEl = root.querySelector<HTMLElement>('[data-active-count]');
    const sidebarToggle = root.querySelector<HTMLButtonElement>('[data-sidebar-toggle]');
    const sidebarBody = root.querySelector<HTMLElement>('[data-sidebar-body]');
    const rows = Array.from(root.querySelectorAll<HTMLElement>('[data-results] [data-row]'));
    const groups = Array.from(root.querySelectorAll<HTMLElement>('[data-results] [data-group]'));
    const count = root.querySelector<HTMLElement>('[data-count]');
    const noResults = root.querySelector<HTMLElement>('[data-no-results]');
    // There are two pagination bars (top + bottom) — drive them together.
    const paginations = Array.from(root.querySelectorAll<HTMLElement>('[data-pagination]'));
    const pageInfos = Array.from(root.querySelectorAll<HTMLElement>('[data-page-info]'));
    const prevBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-prev]'));
    const nextBtns = Array.from(root.querySelectorAll<HTMLButtonElement>('[data-next]'));

    let page = 1;

    // Restore filter + pagination state from the URL query, so returning from a
    // detail page — or opening a shared link — reproduces the same view.
    const params = new URLSearchParams(location.search);
    if (input && params.has('q')) input.value = params.get('q')!;
    if (cityFilter && params.has('city')) cityFilter.value = params.get('city')!;
    if (venueFilter && params.has('venue')) venueFilter.value = params.get('venue')!;
    if (festivalFilter && params.has('festival')) festivalFilter.value = params.get('festival')!;
    if (dateFrom && params.has('from')) dateFrom.value = params.get('from')!;
    if (dateTo && params.has('to')) dateTo.value = params.get('to')!;
    if (pageSizeSel && params.has('size')) pageSizeSel.value = params.get('size')!;
    if (params.has('page')) page = Math.max(1, parseInt(params.get('page')!, 10) || 1);

    // "Now" by the viewer's clock — the build-time upcoming filter freezes on
    // a static site, so we re-floor here so past concerts never show. We floor
    // to the current minute (not midnight) so a concert earlier today drops off
    // once its start time has passed.
    const now = new Date();
    const pad = (n: number) => String(n).padStart(2, '0');
    const nowLocal = `${now.getFullYear()}-${pad(now.getMonth() + 1)}-${pad(now.getDate())}T${pad(now.getHours())}:${pad(now.getMinutes())}`;

    function matches(row: HTMLElement) {
      const q = (input?.value ?? '').trim().toLowerCase();
      const city = cityFilter?.value ?? '';
      const venue = venueFilter?.value ?? '';
      const festival = festivalFilter?.value ?? '';
      const from = dateFrom?.value ?? '';
      const to = dateTo?.value ?? '';
      const date = row.dataset.date ?? '';
      // data-start is "YYYY-MM-DDTHH:MM"; same-format string compare against
      // nowLocal handles both the day and the time in one shot.
      const start = row.dataset.start ?? `${date}T23:59`;
      return (
        start >= nowLocal &&
        (!q || (row.dataset.search ?? '').includes(q)) &&
        (!city || row.dataset.city === city) &&
        (!venue || row.dataset.venue === venue) &&
        (!festival || row.dataset.festival === festival) &&
        (!from || date >= from) &&
        (!to || date <= to)
      );
    }

    function activeFilters() {
      let n = 0;
      if ((input?.value ?? '').trim()) n++;
      if (cityFilter?.value) n++;
      if (venueFilter?.value) n++;
      if (festivalFilter?.value) n++;
      if (dateFrom?.value) n++;
      if (dateTo?.value) n++;
      return n;
    }

    // Mirror the current state into the URL (replaceState — no history spam) and
    // remember it for the detail page's back link.
    function syncUrl() {
      const p = new URLSearchParams();
      const q = (input?.value ?? '').trim();
      if (q) p.set('q', q);
      if (cityFilter?.value) p.set('city', cityFilter.value);
      if (venueFilter?.value) p.set('venue', venueFilter.value);
      if (festivalFilter?.value) p.set('festival', festivalFilter.value);
      if (dateFrom?.value) p.set('from', dateFrom.value);
      if (dateTo?.value) p.set('to', dateTo.value);
      if (pageSizeSel && pageSizeSel.value !== '25') p.set('size', pageSizeSel.value);
      if (page > 1) p.set('page', String(page));
      const qs = p.toString();
      const url = location.pathname + (qs ? `?${qs}` : '');
      history.replaceState(history.state, '', url);
      try {
        sessionStorage.setItem('jk:lastListing', url);
      } catch (e) {}
    }

    function render() {
      const matched = rows.filter(matches);
      const total = matched.length;
      const raw = pageSizeSel?.value ?? '25';
      const size = raw === 'all' ? Math.max(total, 1) : parseInt(raw, 10);
      const pageCount = Math.max(1, Math.ceil(total / size));
      if (page > pageCount) page = pageCount;
      if (page < 1) page = 1;
      const start = (page - 1) * size;
      const end = start + size;
      const shown = new Set(matched.slice(start, end));

      for (const row of rows) row.hidden = !shown.has(row);
      for (const g of groups) g.hidden = !g.querySelector('[data-row]:not([hidden])');

      if (count) {
        count.textContent = total === 0
          ? '0 konserter'
          : `Visar ${start + 1}–${Math.min(end, total)} av ${total} konserter`;
      }
      for (const el of pageInfos) el.textContent = `Sida ${page} / ${pageCount}`;
      for (const b of prevBtns) b.disabled = page <= 1;
      for (const b of nextBtns) b.disabled = page >= pageCount;
      for (const nav of paginations) nav.hidden = pageCount <= 1;
      if (noResults) noResults.style.display = total === 0 ? 'block' : 'none';

      if (activeCountEl) {
        const a = activeFilters();
        activeCountEl.textContent = a === 0 ? 'Inga aktiva' : `${a} aktiva`;
      }

      syncUrl();
    }

    function reset() {
      page = 1;
      render();
    }

    function clearFilters() {
      if (input) input.value = '';
      if (cityFilter) cityFilter.value = '';
      if (venueFilter) venueFilter.value = '';
      if (festivalFilter) festivalFilter.value = '';
      if (dateFrom) dateFrom.value = '';
      if (dateTo) dateTo.value = '';
      if (pageSizeSel) pageSizeSel.value = '25';
      reset();
    }

    input?.addEventListener('input', reset);
    cityFilter?.addEventListener('change', reset);
    venueFilter?.addEventListener('change', reset);
    festivalFilter?.addEventListener('change', reset);
    dateFrom?.addEventListener('change', reset);
    dateTo?.addEventListener('change', reset);
    pageSizeSel?.addEventListener('change', reset);
    resetBtn?.addEventListener('click', clearFilters);
    sidebarToggle?.addEventListener('click', () => {
      const open = sidebarBody?.hasAttribute('data-open') ?? false;
      sidebarBody?.toggleAttribute('data-open', !open);
      sidebarToggle.setAttribute('aria-expanded', open ? 'false' : 'true');
    });
    for (const b of prevBtns) b.addEventListener('click', () => goTo(page - 1));
    for (const b of nextBtns) b.addEventListener('click', () => goTo(page + 1));

    function goTo(p: number) {
      page = p;
      render();
    }

    render();
  }

  document.addEventListener('astro:page-load', initBrowser);
</script>
