---
import Layout from '../layouts/Layout.astro';
import ConcertBrowser from '../components/ConcertBrowser.astro';
import { getUpcomingConcerts } from '../lib/concerts';
import styles from './index.module.css';

const upcoming = await getUpcomingConcerts();
const site = Astro.site ?? Astro.url;

// Lightweight ItemList — full MusicEvent markup lives on each detail page.
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Kommande jazzkonserter i Sverige',
  numberOfItems: upcoming.length,
  itemListElement: upcoming.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${c.data.artist} – ${c.data.venue}`,
    url: new URL(`/concerts/${c.id}/`, site).href,
  })),
};
---

<Layout title="Jazzdatum.se" jsonLd={itemListSchema}>
  <section class={styles.hero}>
    <h1>Jazzkonserter i Sverige</h1>
  </section>

  <section class={styles.section}>
    <ConcertBrowser concerts={upcoming} />
  </section>

  <section class={styles.about}>
    <h2>Om Jazzdatum.se</h2>
    <p>
      Av <a href="https://urre.me">Urban Sandén</a>. Nya konserter läggs till kontinuerligt. Besök också <a href="https://www.jazztips.se/">Jazztips.se</a>
    </p>
  </section>
</Layout>
