---
import Layout from '../layouts/Layout.astro';
import SiteAbout from '../components/SiteAbout.astro';
import shell from './concerts/detail.module.css';
import styles from './kontakt.module.css';

// Google Form embed (?embedded=true renders the chrome-free version).
const formSrc =
  'https://docs.google.com/forms/d/e/1FAIpQLSc4aZ_3tnaudSC7UeVn9ePkeLjuzM-KniDKvAl0pzXIh_UEhw/viewform?embedded=true';
---

<Layout
  title="Kontakt"
  description="Tipsa Jazzkonserter.se om konserter eller spelställen som saknas."
  fullWidth
>
  <div class={shell.browser}>
    <aside class={shell.sidebar}>
      <div class={shell.sidebarInner}>
        <a class={shell.back} href="/">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" />
          </svg>
          Alla konserter
        </a>

        <SiteAbout />
      </div>
    </aside>

    <div class={shell.main}>
      <article class={styles.content}>
        <h1 class={styles.title}>Kontakt</h1>
        <p class={styles.lead}>
          Saknar du konserter, eller vill du tipsa om ett spelställe? Fyll i formuläret nedan
          så lägger vi till källan.
        </p>

        <p class={styles.contact}>Get in touch: <a href="mailto:hej@urre.me">hej@urre.me</a></p>

        <div class={styles.formWrap}>
          <iframe
            class={styles.form}
            src={formSrc}
            title="Lägg till källa – kontaktformulär"
            loading="lazy"
          >Läser in formuläret…</iframe>
        </div>
      </article>
    </div>
  </div>
</Layout>
