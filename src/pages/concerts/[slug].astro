---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { formatDate } from '../../lib/concerts';
import { venueColor, venueTextColor, venueTint, venueTintDark } from '../../lib/venueColor';
import { musicEventSchema } from '../../lib/eventSchema';
import AddToCalendar from '../../components/AddToCalendar.astro';
import SiteAbout from '../../components/SiteAbout.astro';
import styles from './detail.module.css';

export async function getStaticPaths() {
  const concerts = await getCollection('concerts');
  return concerts.map((concert) => ({
    params: { slug: concert.id },
    props: { concert },
  }));
}

const { concert } = Astro.props;
const { data } = concert;
const { Content } = await render(concert);

const vc = venueColor(data.venue);
const vcText = venueTextColor(vc);
const vcTint = venueTint(vc);
const vcTintDark = venueTintDark(vc);
const hasBody = (concert.body ?? '').trim().length > 0;
const showTitle = data.title && data.title !== data.artist;
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(data.venue)}`;
const eventSchema = musicEventSchema(concert, Astro.site ?? Astro.url);

const metaDescription =
  data.description ?? `${data.artist} på ${data.venue}, ${formatDate(data.date)}.`;
---

<Layout
  title={`${data.artist} – ${data.venue}`}
  description={metaDescription}
  image={data.image}
  ogType="article"
  jsonLd={eventSchema}
  fullWidth
>
  <div class={styles.browser} style={`--vc:${vc};--vc-text:${vcText};--vc-tint:${vcTint};--vc-tint-dark:${vcTintDark}`}>
    <aside class={styles.sidebar}>
      <div class={styles.sidebarInner}>
        <a class={styles.back} href="/" data-back>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M15 6l-6 6 6 6" />
          </svg>
          Alla konserter
        </a>

        <SiteAbout />
      </div>
    </aside>

    <div class={styles.main}>
      <article class={styles.wrap}>
        <header class={styles.hero}>
          <div class={styles.heroHead}>
            <span class={styles.venue}>{data.venue}</span>
          </div>

          <h1 class={styles.artist}>{data.artist}</h1>
          {showTitle && <p class={styles.title}>{data.title}</p>}

          <dl class={styles.facts}>
            <div class={styles.fact}>
              <dt>Datum</dt>
              <dd>{formatDate(data.date)}</dd>
            </div>
            {data.time && (
              <div class={styles.fact}>
                <dt>Tid</dt>
                <dd>{data.time}</dd>
              </div>
            )}
            {data.price && (
              <div class={styles.fact}>
                <dt>Pris</dt>
                <dd>{data.price}</dd>
              </div>
            )}
            {data.genre.length > 0 && (
              <div class={styles.fact}>
                <dt>Genre</dt>
                <dd>{data.genre.join(', ')}</dd>
              </div>
            )}
            {data.festival && data.festival !== data.venue && (
              <div class={styles.fact}>
                <dt>Festival</dt>
                <dd>{data.festival}</dd>
              </div>
            )}
          </dl>

          <div class={styles.actions}>
            {data.ticketUrl && (
              <a class={styles.cta} href={data.ticketUrl} target="_blank" rel="noopener">
                Köp biljetter
              </a>
            )}
            <AddToCalendar
              title={data.artist}
              venue={data.venue}
              date={data.date}
              time={data.time}
              description={data.description}
              uid={concert.id}
              variant="full"
            />
            {data.venueUrl && (
              <a class={styles.secondary} href={data.venueUrl} target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18" />
                </svg>
                Webbplats
              </a>
            )}
            <a class={styles.secondary} href={mapsUrl} target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M21 10c0 7-9 12-9 12s-9-5-9-12a9 9 0 0 1 18 0Z" />
                <circle cx="12" cy="10" r="3" />
              </svg>
              Visa på karta
            </a>
          </div>
        </header>

        {hasBody && (
          <div class={styles.content}>
            <Content />
          </div>
        )}
      </article>
    </div>
  </div>
</Layout>

<script>
  // Make "Alla konserter" return to the filtered listing the visitor came from.
  function initBack() {
    const back = document.querySelector<HTMLAnchorElement>('[data-back]');
    if (!back) return;
    // Point the link at the remembered listing URL (also makes right-click /
    // open-in-new-tab and direct-landing fall back sensibly).
    const last = sessionStorage.getItem('jk:lastListing');
    if (last) back.setAttribute('href', last);
    if (back.dataset.bound) return;
    back.dataset.bound = '1';
    back.addEventListener('click', (e) => {
      // Came from the listing this session → go back so filters AND scroll
      // position are restored; otherwise let the href navigation happen.
      if (sessionStorage.getItem('jk:lastListing') && history.length > 1) {
        e.preventDefault();
        history.back();
      }
    });
  }
  document.addEventListener('astro:page-load', initBack);
</script>
